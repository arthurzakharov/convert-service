RAILWAY_TOKEN=your-railway-token

# Port the service listens on
PORT=3100

# Convert SDK keys — one per project
# Found in Convert dashboard: Project Settings → SDK Keys
CONVERT_SDK_KEY_PASSEXPERTEN=your-convert-sdk-key-for-passexperten
CONVERT_SDK_KEY_BUSSGELDCHECK=your-convert-sdk-key-for-bussgeldcheck

# Convert environment — "staging" | "live"
CONVERT_ENVIRONMENT=live

# How often to refresh project config from Convert CDN (ms)
# Default: 5 minutes
CONVERT_DATA_REFRESH_INTERVAL=300000

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=https://xxx.com.de/abc,https://yyy.com/abc
