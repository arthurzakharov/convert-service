{
  "name": "convert-service",
  "version": "1.0.0",
  "description": "Server-side Convert.com SDK proxy service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@convertcom/js-sdk": "^4.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "geoip-lite": "^1.4.10",
    "ua-parser-js": "^2.0.10"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20.14.0",
    "@types/ua-parser-js": "^0.7.39",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
